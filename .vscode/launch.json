{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/Debug/stm32_asm_interpreter.elf",
            "request": "launch",
            "type": "cortex-debug",
            "runToEntryPoint": "main",
            "servertype": "stlink",
            "device": "STM32L476RG",
            "interface": "swd",
            "serialNumber": "",
            "svdFile": "${workspaceFolder}/.vscode/STM32L476.svd",
            "preLaunchTask": "Build STM32 (Debug)",
            "showDevDebugOutput": "raw",
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 4
            }
        }
    ]
}
